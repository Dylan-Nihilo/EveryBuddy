{
  "name": "everybuddy",
  "version": "0.1.3",
  "description": "Gacha-hatched terminal companions that live in your tmux. Draw a pet, AI writes its soul, it watches your shell and reacts.",
  "type": "module",
  "bin": {
    "buddy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Dylan-Nihilo/EveryBuddy.git"
  },
  "homepage": "https://github.com/Dylan-Nihilo/EveryBuddy",
  "author": "Dylan Thomas",
  "license": "MIT",
  "keywords": [
    "terminal",
    "tmux",
    "companion",
    "pet",
    "gacha",
    "ascii-art",
    "cli",
    "sidecar"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@8.6.12",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
